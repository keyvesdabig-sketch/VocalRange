<!DOCTYPE html>

<html class="dark" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <link
        href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&amp;family=Manrope:wght@300;400;500;600;700;800&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "background": "#160625",
                        "on-tertiary": "#655400",
                        "inverse-surface": "#fff7fe",
                        "on-background": "#f3deff",
                        "secondary": "#00f1fe",
                        "on-secondary-fixed": "#004145",
                        "tertiary-dim": "#efc900",
                        "surface-container": "#241036",
                        "tertiary": "#ffe792",
                        "primary-dim": "#a892f0",
                        "secondary-container": "#00696f",
                        "on-primary": "#331b74",
                        "surface-bright": "#3a2051",
                        "on-secondary-fixed-variant": "#006065",
                        "on-primary-fixed-variant": "#3d267e",
                        "error-container": "#a70138",
                        "surface": "#160625",
                        "on-surface-variant": "#b9a2ca",
                        "primary": "#b6a0ff",
                        "surface-tint": "#b6a0ff",
                        "primary-fixed-dim": "#a892f0",
                        "inverse-on-surface": "#614d71",
                        "on-primary-container": "#270969",
                        "on-surface": "#f3deff",
                        "on-primary-fixed": "#18004c",
                        "on-tertiary-fixed-variant": "#665500",
                        "tertiary-fixed": "#ffd709",
                        "on-tertiary-container": "#5b4b00",
                        "surface-container-high": "#2b153f",
                        "on-error-container": "#ffb2b9",
                        "secondary-fixed-dim": "#00e2ee",
                        "surface-dim": "#160625",
                        "surface-container-low": "#1d0a2d",
                        "on-tertiary-fixed": "#453900",
                        "secondary-dim": "#00e2ee",
                        "surface-container-highest": "#321b48",
                        "tertiary-container": "#ffd709",
                        "surface-variant": "#321b48",
                        "surface-container-lowest": "#000000",
                        "outline-variant": "#534063",
                        "on-secondary": "#00555a",
                        "on-error": "#490013",
                        "primary-container": "#a892f0",
                        "error-dim": "#d73357",
                        "on-secondary-container": "#e2fdff",
                        "outline": "#826d93",
                        "tertiary-fixed-dim": "#efc900",
                        "inverse-primary": "#6550a9",
                        "primary-fixed": "#b6a0ff",
                        "secondary-fixed": "#00f1fe",
                        "error": "#ff6e84"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                    "fontFamily": {
                        "headline": ["Space Grotesk"],
                        "body": ["Manrope"],
                        "label": ["Manrope"]
                    }
                },
            },
        }
    </script>
    <style>
        body {
            background-color: #160625;
            color: #f3deff;
            font-family: 'Manrope', sans-serif;
            overflow-x: hidden;
        }

        .organic-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            background: radial-gradient(circle at 20% 30%, #3a2051 0%, transparent 40%),
                radial-gradient(circle at 80% 70%, #18004c 0%, transparent 40%);
            filter: blur(80px);
        }

        .glass-panel {
            background: rgba(36, 16, 54, 0.4);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
        }

        .glass-panel-high {
            background: rgba(50, 27, 72, 0.6);
            backdrop-filter: blur(40px);
            -webkit-backdrop-filter: blur(40px);
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .text-glow-primary {
            text-shadow: 0 0 10px rgba(182, 160, 255, 0.5);
        }

        .button-glow {
            box-shadow: 0 0 20px rgba(182, 160, 255, 0.15);
        }

        .inner-glow {
            box-shadow: inset 0 0 20px rgba(182, 160, 255, 0.05);
        }
    </style>
    <style>
        body {
            min-height: max(884px, 100dvh);
        }
    </style>
</head>

<body class="min-h-screen">
    <div class="organic-bg"></div>
    <!-- TopAppBar -->
    <header
        class="fixed top-0 w-full z-50 flex justify-between items-center px-6 py-4 bg-purple-950/40 backdrop-blur-xl shadow-[0_8px_32px_0_rgba(24,0,76,0.12)]">
        <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full overflow-hidden border border-primary/20 bg-surface-container-highest">
                <img alt="User Profile"
                    data-alt="close-up portrait of a stylized 3D avatar with futuristic headphones in vibrant violet and cyan lighting"
                    src="https://lh3.googleusercontent.com/aida-public/AB6AXuAK4wtNeM9kdGtkLZ_omng3WO1GipZnxrkcXOLIvKM0oItNEFnz91-mn7OZ6Uvy5coorD134hBvZ76DFglYrWg76WpATdkNyJIXLvvV3dSf2YIUl0XH5NfTWa3yIU5VPqC1UrLhhXsru7FO219M0KUz3xDP81bobRFwKuUGTP3BKZHSdDifw34jk3toAuUB3t3GACftnS73ZodxYX9YBT77hrL3hjIRsdbfsWWgXGyeRFf0cPurQkdT1VryENvvWXPAHdnl-gx4sIMD" />
            </div>
        </div>
        <h1
            class="text-2xl font-bold text-[#b6a0ff] drop-shadow-[0_0_8px_rgba(182,160,255,0.5)] font-['Space_Grotesk'] tracking-tighter uppercase">
            VOICECRACK
        </h1>
        <button
            class="w-10 h-10 flex items-center justify-center rounded-full text-[#b6a0ff] hover:bg-white/5 transition-colors active:scale-95 duration-200">
            <span class="material-symbols-outlined" data-icon="settings">settings</span>
        </button>
    </header>
    <main class="pt-24 pb-32 px-6 max-w-5xl mx-auto space-y-12">
        <!-- Gamification Summary Card -->
        <section class="glass-panel rounded-[2rem] p-6 relative overflow-hidden inner-glow">
            <div class="flex items-center justify-between mb-6">
                <div class="space-y-1">
                    <span
                        class="font-label text-[10px] uppercase tracking-widest text-on-surface-variant font-bold">Current
                        Resonance</span>
                    <h2 class="font-headline text-3xl font-bold text-on-surface">Level 24</h2>
                </div>
                <div class="text-right">
                    <span class="font-label text-[10px] uppercase tracking-widest text-secondary font-bold">Rank</span>
                    <p class="font-headline text-xl font-bold text-secondary">Vocalist Pro</p>
                </div>
            </div>
            <div class="space-y-3">
                <div class="flex justify-between items-end">
                    <span class="font-body text-sm font-semibold text-on-surface/80">3,450 / 5,000 XP</span>
                    <span class="font-body text-xs text-primary font-bold">72%</span>
                </div>
                <div class="h-3 w-full bg-surface-container-lowest rounded-full overflow-hidden p-0.5">
                    <div class="h-full bg-primary rounded-full drop-shadow-[0_0_12px_rgba(182,160,255,0.8)]"
                        style="width: 72%"></div>
                </div>
            </div>
            <!-- Asymmetric accent -->
            <div class="absolute -right-4 -bottom-4 w-24 h-24 bg-primary/10 blur-3xl rounded-full"></div>
        </section>
        <!-- Hero Section -->
        <section class="text-center py-8 space-y-6">
            <div class="relative inline-block">
                <h2
                    class="font-headline text-5xl md:text-7xl font-extrabold tracking-tighter text-on-surface leading-[0.9] text-glow-primary">
                    Find Your<br />Frequency
                </h2>
                <div
                    class="absolute -z-10 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[120%] h-[120%] bg-primary/5 blur-[100px]">
                </div>
            </div>
            <p class="font-body text-on-surface-variant max-w-sm mx-auto leading-relaxed text-sm">
                Unlock the hidden architecture of your voice with high-fidelity sonic analysis and real-time mapping.
            </p>
            <div class="pt-4">
                <button
                    class="bg-primary text-on-primary font-headline font-bold px-10 py-5 rounded-full text-lg button-glow active:scale-95 transition-all">
                    Start Test
                </button>
            </div>
        </section>
        <!-- Bento Grid for Tests -->
        <section class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Large Main Test -->
            <div
                class="glass-panel rounded-[2.5rem] p-8 space-y-6 md:col-span-2 group hover:bg-surface-container/60 transition-all cursor-pointer">
                <div class="flex justify-between items-start">
                    <div class="space-y-2">
                        <div class="flex items-center gap-2 text-secondary">
                            <span class="material-symbols-outlined text-lg" data-icon="analytics">analytics</span>
                            <span class="font-label text-xs uppercase tracking-[0.2em] font-bold">Comprehensive
                                Analysis</span>
                        </div>
                        <h3 class="font-headline text-4xl font-bold">The Range Test</h3>
                    </div>
                    <span
                        class="material-symbols-outlined text-primary text-4xl group-hover:translate-x-2 transition-transform"
                        data-icon="arrow_forward_ios">arrow_forward_ios</span>
                </div>
                <div class="h-48 rounded-2xl overflow-hidden relative">
                    <img class="w-full h-full object-cover opacity-60 mix-blend-screen"
                        data-alt="abstract visualization of sound waves as flowing neon violet lines in a dark space, high-tech aesthetic"
                        src="https://lh3.googleusercontent.com/aida-public/AB6AXuD-EEn5FLw3d80qQT2_6UYFwxZWxVeN0qJtxOGTnzbeAUN28LmMwEeSrNS3itzU4tkfn90GL6-hztgx0bFMitTBeXdTo7MCAnETkgcPXEo4UIYIdQgWJAd5x1Rhr1rFlGNOOetxfkeeCcNnXWRALNzBjwAoVAh94rIYdxPgHtQ66PK4IDgEACI9cr2mAxolEeiIMsrsuouMRkwOu1S7LiE2icd5_5-xru2KIvcHkvPXirFK4Bdjt3RVdk-ULWkltB9CwA4c8_goTIt9" />
                    <div
                        class="absolute inset-0 bg-gradient-to-t from-surface-container via-transparent to-transparent">
                    </div>
                </div>
            </div>
            <!-- Deep Low Card -->
            <div
                class="glass-panel-high rounded-[2rem] p-8 space-y-4 hover:scale-[1.02] transition-transform cursor-pointer">
                <div
                    class="w-12 h-12 bg-surface-container-lowest rounded-xl flex items-center justify-center text-primary mb-4">
                    <span class="material-symbols-outlined text-3xl"
                        data-icon="keyboard_double_arrow_down">keyboard_double_arrow_down</span>
                </div>
                <h4 class="font-headline text-2xl font-bold">Deep Low</h4>
                <p class="font-body text-sm text-on-surface-variant leading-relaxed">Discover your sub-bass resonance
                    and chest-voice foundation.</p>
                <div class="flex items-center gap-2 pt-2">
                    <span class="text-tertiary font-headline font-bold">Best: E2</span>
                    <span class="text-on-surface-variant/40">•</span>
                    <span class="text-on-surface-variant/60 font-body text-xs">Top 5%</span>
                </div>
            </div>
            <!-- Peak High Card -->
            <div
                class="glass-panel-high rounded-[2rem] p-8 space-y-4 hover:scale-[1.02] transition-transform cursor-pointer">
                <div
                    class="w-12 h-12 bg-surface-container-lowest rounded-xl flex items-center justify-center text-secondary mb-4">
                    <span class="material-symbols-outlined text-3xl"
                        data-icon="keyboard_double_arrow_up">keyboard_double_arrow_up</span>
                </div>
                <h4 class="font-headline text-2xl font-bold">Peak High</h4>
                <p class="font-body text-sm text-on-surface-variant leading-relaxed">Map your head-voice limits and find
                    your whistle register potential.</p>
                <div class="flex items-center gap-2 pt-2">
                    <span class="text-tertiary font-headline font-bold">Best: C6</span>
                    <span class="text-on-surface-variant/40">•</span>
                    <span class="text-on-surface-variant/60 font-body text-xs">Top 12%</span>
                </div>
            </div>
        </section>
        <!-- Decorative Spacer -->
        <div class="h-24"></div>
    </main>
    <!-- BottomNavBar -->
    <nav
        class="fixed bottom-0 left-0 w-full z-50 flex justify-around items-center pt-3 pb-8 px-4 bg-[#160625]/60 backdrop-blur-2xl shadow-[0_-10px_40px_rgba(182,160,255,0.1)] rounded-t-[2rem]">
        <!-- Studio Tab (Active) -->
        <a class="flex flex-col items-center justify-center text-[#b6a0ff] drop-shadow-[0_0_10px_#b6a0ff] active:scale-90 transition-transform"
            href="#">
            <span class="material-symbols-outlined mb-1" data-icon="mic_external_on"
                style="font-variation-settings: 'FILL' 1;">mic_external_on</span>
            <span class="font-['Manrope'] text-[10px] font-semibold uppercase tracking-widest">Studio</span>
        </a>
        <!-- Vitals Tab -->
        <a class="flex flex-col items-center justify-center text-[#f3deff]/40 hover:text-[#00f1fe] transition-all active:scale-90"
            href="#">
            <span class="material-symbols-outlined mb-1" data-icon="graphic_eq">graphic_eq</span>
            <span class="font-['Manrope'] text-[10px] font-semibold uppercase tracking-widest">Vitals</span>
        </a>
        <!-- Arena Tab -->
        <a class="flex flex-col items-center justify-center text-[#f3deff]/40 hover:text-[#00f1fe] transition-all active:scale-90"
            href="#">
            <span class="material-symbols-outlined mb-1" data-icon="emoji_events">emoji_events</span>
            <span class="font-['Manrope'] text-[10px] font-semibold uppercase tracking-widest">Arena</span>
        </a>
        <!-- Profile Tab -->
        <a class="flex flex-col items-center justify-center text-[#f3deff]/40 hover:text-[#00f1fe] transition-all active:scale-90"
            href="#">
            <span class="material-symbols-outlined mb-1" data-icon="account_circle">account_circle</span>
            <span class="font-['Manrope'] text-[10px] font-semibold uppercase tracking-widest">Profile</span>
        </a>
    </nav>
</body>

</html>